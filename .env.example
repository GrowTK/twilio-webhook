PORT=3000
PUBLIC_URL=https://your-app.up.railway.app

# Tunable without redeployment
VAD_CONFIDENCE_THRESHOLD=0.5
VAD_HOLD_OFF_MS=350
VAD_SILENCE_MS=600
RNNOISE_ENABLED=true
BARGE_IN_COOLDOWN_MS=500

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+61xxxxxxxxxx

VOICE_PIPELINE_URL=https://your-pipeline.up.railway.app/voice
VOICE_PIPELINE_API_KEY=your-pipeline-api-key

#SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

#ANTHROPIC
ANTHROPIC_API_KEY=sk-ant-xxx
