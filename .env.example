PORT=3000
PUBLIC_URL=https://your-app.up.railway.app


# Tunable without redeployment
VAD_CONFIDENCE_THRESHOLD=0.5
VAD_HOLD_OFF_MS=350
VAD_SILENCE_MS=600
RNNOISE_ENABLED=true
BARGE_IN_COOLDOWN_MS=500



TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER= +61xxxxxxxxxx


VOICE_PIPELINE_URL=https://voice-pipeline-production-b953.up.railway.app/voice
VOICE_PIPELINE_API_KEY=x-api-key: your-pipeline-api-key
#Body: { "audio": "YOUR_BASE64_STRING_HERE" }

#RAILWAY
RAILWAY_PROJECT=frendlia-core
RAILWAY_API_TOKEN=your-railway-token
#API Code 1 your-railway-token
#API Code 2 your-railway-token

#SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

#ANTHROPIC
ANTHROPIC_API_KEY=sk-ant-xxx